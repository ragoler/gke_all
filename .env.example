# ==============================================================================
# GKE Feature Showcase Hub - Configuration Template
# Copy this file to .env and fill in your details.
# Do NOT commit the .env file to version control.
# ==============================================================================

# Orchestrator Operational Modes
# MODE can be MOCK (local offline development) or REAL (live deployment on GKE)
MODE=MOCK

# Security & Embedded JWT Token Authentication
ADMIN_AUTHENTICATION_ENABLED=TRUE
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin-password-change-me-12345
JWT_SECRET_KEY=your-secure-jwt-signing-secret-key-change-me

# GKE Showcase Base Cluster Infrastructure Settings
PROJECT_NAME=your-gcp-project-id
REGION=us-west1
CLUSTER_NAME=gke-showcase-cluster
# CLUSTER_VERSION is optional: leave unset to use GKE's release-channel default
# (recommended — always valid & current). Pin only if you need a specific version
# (GPU time-sharing requires >= 1.35.2-gke.1485000), e.g. CLUSTER_VERSION=1.35.x-gke.xxxx
# CLUSTER_VERSION=
NODE_POOL_NAME=showcase-node-pool
MACHINE_TYPE=e2-standard-2
ARTIFACT_REGISTRY_REPO=gke-showcase-repo

# Network & Shared Gateway Configuration
GATEWAY_NAME=external-http-gateway

# AI / LLM Integration (Workload Identity vs API Key Fallback)
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GEMINI_API_KEY=your-gemini-api-key-fallback

# Showcase 2 (GPU Inference) Configuration
MODEL_NAME=gemma-2b-it
GCS_MODEL_BUCKET=vertex-model-garden-public-us
